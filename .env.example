# Copy this file to .env.local and add your own values.
# .env.local is gitignored so your keys never get committed.

# OpenWeatherMap API key - used by the Weather Widget on the Trip Detail screen.
# Get a free key at https://openweathermap.org/api
# The app still runs without this - the weather widget will just show an error state.
EXPO_PUBLIC_WEATHER_API_KEY=api key here