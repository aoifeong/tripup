{
  "expo": {
    "name": "TripUp",
    "slug": "tripup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tripuplogo.png",
    "scheme": "tripup",
    "userInterfaceStyle": "light", 
  
    
    // ADD THESE BRANDING FIELDS:
    "primaryColor": "#3b82f6",
    "backgroundColor": "#f9fafb",
    
    
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3b82f6",  
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/tripuplogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f9fafb"
          }

      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
